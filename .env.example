# Copy this file to .env before deployment:
#   cp .env.example .env
# Replace the example admin password hash and fill your subscription URL before exposing the service.

# Image tag used by docker-compose.yml for GHCR deployments.
IMAGE_TAG=main

# Admin web credentials
ADMIN_USERNAME=admin
# Example SHA256("admin"). Replace in production.
ADMIN_PASSWORD_HASH=8c6976e5b5410415bde908bd4dee15dfb167a9c873fc4bb8a81f6f2ab448a918

# Subscription source
SUBSCRIPTION_URL=

# Refresh intervals (seconds)
SUBSCRIPTION_REFRESH_INTERVAL=900
HEALTH_CHECK_INTERVAL=60

# Runtime scheduling
RUNTIME_MODE=single_active
POOL_ALGORITHM=sequential

# Exposed entrypoints
HTTP_LISTEN_PORT=7777
SOCKS_LISTEN_PORT=7780
ADMIN_LISTEN_PORT=8080

# Runtime paths inside the container
SINGBOX_BINARY=sing-box
DB_PATH=data/proxypools.db

# Optional dispatcher settings.
# If you enable dispatcher, use ports different from the default proxy entrypoints above.
# DISPATCHER_ENABLED=true
# DISPATCHER_HTTP_LISTEN_PORT=8787
# DISPATCHER_SOCKS_LISTEN_PORT=8788
# DISPATCHER_ALGORITHM=sequential
